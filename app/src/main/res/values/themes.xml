<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.Hearth" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/header_bg</item>
    </style>

    <!-- Splash Screen theme. -->
    <style name="Theme.Hearth.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/header_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.Hearth</item>
    </style>
</resources>
